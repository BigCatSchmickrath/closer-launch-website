---
// Closer Launch Homepage
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Closer Launch — Growth Partners for Home Service Companies</title>
  <meta name="description" content="Closer Launch partners with ambitious home service companies ready to scale. We optimize your entire operation and build a company worth significantly more.">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/global.css">
</head>
<body>

  <!-- HEADER -->
  <header class="header" id="header">
    <div class="container">
      <a href="#" aria-label="Closer Launch Home">
        <img src="/images/logo-white.png" alt="Closer Launch" class="header-logo">
      </a>
      <a href="#waitlist" class="btn-primary">
        Join Waitlist
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <img src="/images/logo-white.png" alt="Closer Launch" class="hero-logo">
    <h1>Scaling Home Service Companies to<br><span class="accent">$10M+ Exits</span></h1>
    <p class="hero-description">
      Closer Launch partners with ambitious home service companies ready to scale — not as another vendor, but as growth partners with skin in the game. Your win is our win.
    </p>
    <a href="#waitlist" class="btn-primary">
      Get on the Waitlist
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </section>

  <!-- LOGO MARQUEE -->
  <section class="marquee-section">
    <p class="marquee-label">Trusted By Industry Leaders</p>
    <div class="marquee-track" id="marqueeTrack">
      <!-- Set 1 -->
      <div class="marquee-item"><img src="/images/client-1-white.png" alt="Client 1"></div>
      <div class="marquee-item"><img src="/images/client-2-white.png" alt="Client 2"></div>
      <div class="marquee-item"><img src="/images/client-3-white.png" alt="Client 3"></div>
      <div class="marquee-item"><img src="/images/client-4-white.png" alt="Client 4"></div>
      <div class="marquee-item"><img src="/images/client-5-white.png" alt="Client 5"></div>
      <div class="marquee-item"><img src="/images/client-6-white.png" alt="Client 6"></div>
      <!-- Set 2 -->
      <div class="marquee-item"><img src="/images/client-1-white.png" alt="Client 1"></div>
      <div class="marquee-item"><img src="/images/client-2-white.png" alt="Client 2"></div>
      <div class="marquee-item"><img src="/images/client-3-white.png" alt="Client 3"></div>
      <div class="marquee-item"><img src="/images/client-4-white.png" alt="Client 4"></div>
      <div class="marquee-item"><img src="/images/client-5-white.png" alt="Client 5"></div>
      <div class="marquee-item"><img src="/images/client-6-white.png" alt="Client 6"></div>
      <!-- Set 3 -->
      <div class="marquee-item"><img src="/images/client-1-white.png" alt="Client 1"></div>
      <div class="marquee-item"><img src="/images/client-2-white.png" alt="Client 2"></div>
      <div class="marquee-item"><img src="/images/client-3-white.png" alt="Client 3"></div>
      <div class="marquee-item"><img src="/images/client-4-white.png" alt="Client 4"></div>
      <div class="marquee-item"><img src="/images/client-5-white.png" alt="Client 5"></div>
      <div class="marquee-item"><img src="/images/client-6-white.png" alt="Client 6"></div>
    </div>
  </section>

  <!-- VALUE PROP -->
  <section style="padding: 80px 0; background: var(--dark-secondary);">
    <div class="container" style="max-width: 780px; text-align: center;">
      <div class="fade-up">
        <span class="section-label">The Partnership</span>
        <h2 class="section-title" style="margin-bottom: 24px;">Built to Dominate Your Market</h2>
        <p style="font-size: 18px; color: var(--text-light); line-height: 1.8;">
          We optimize your entire operation — marketing, sales systems, technician efficiency, and customer experience — and build a company worth significantly more than it is today. We get you ready for a big payday when you exit in the near future. You get a team obsessed with your success because your win is our win. This isn't a retainer relationship. It's a partnership built to dominate your market.
        </p>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section class="about-section" id="about">
    <div class="container">
      <div class="fade-up">
        <span class="section-label">Who We Are</span>
        <h2 class="section-title">Meet the Team</h2>
        <p class="section-subtitle">Three partners, one mission — help home service companies scale to an exit-ready valuation.</p>
      </div>
      <div class="team-grid fade-up">
        <!-- Reese -->
        <div class="team-card" onclick="openTeamModal('reese')">
          <img src="/images/reese.png" alt="Reese" class="team-photo">
          <h3 class="team-name">Reese</h3>
          <p class="team-role">Partner</p>
          <p class="team-bio">Reese built and managed a sales division that closed $1.1M in three months, then scaled a regional operation to $2.5M annually. At Closer Launch, he brings that same execution to your business — optimizing every system from lead generation to customer experience so you scale faster and exit bigger.</p>
        </div>
        <!-- Ryan -->
        <div class="team-card" onclick="openTeamModal('ryan')">
          <img src="/images/ryan.png" alt="Ryan" class="team-photo">
          <h3 class="team-name">Ryan</h3>
          <p class="team-role">Founder</p>
          <p class="team-bio">Ryan scaled a SaaS startup to $500K ARR as VP of Sales, then bootstrapped a B2B agency to $30K/month solo before building Closer Launch. He doesn't sell retainers or promises — he creates partnerships. He teams up with ambitious home service owners and builds businesses engineered for large exits in 2–5 years. Your win is his win.</p>
        </div>
        <!-- Connor -->
        <div class="team-card" onclick="openTeamModal('connor')">
          <img src="/images/connor.png" alt="Connor" class="team-photo">
          <h3 class="team-name">Connor</h3>
          <p class="team-role">Partner</p>
          <p class="team-bio">Connor led marketing for a firm managing $115M+ in assets, attracting clients like Berkshire Hathaway and Amazon, and ran campaigns for Disney, Ford, and Honda. At Closer Launch, he brings that Fortune 500 playbook to home service companies — building the funnels, automation, and revenue systems that turn traffic into booked appointments at scale.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TEAM MODAL -->
  <div id="teamModal" class="modal">
    <div class="modal-overlay" onclick="closeTeamModal()"></div>
    <div class="modal-content">
      <button class="modal-close" onclick="closeTeamModal()">&times;</button>
      <img id="modalPhoto" src="" alt="" class="modal-photo">
      <h3 id="modalName" class="modal-name"></h3>
      <p id="modalRole" class="modal-role"></p>
      <p id="modalBio" class="modal-bio"></p>
      <div class="modal-socials" id="modalSocials">
        <!-- Social icons injected by JS -->
      </div>
    </div>
  </div>

  <!-- STATS -->
  <section class="stats-section">
    <div class="container">
      <div class="fade-up">
        <span class="section-label">Results That Speak</span>
        <h2 class="section-title" style="margin-bottom: 60px;">The Numbers Behind the Partnership</h2>
      </div>
      <div class="stats-grid fade-up" style="grid-template-columns: repeat(3, 1fr);">
        <div class="stat-item">
          <div class="stat-number">100%</div>
          <div class="stat-label">ROI in month one</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">9.7x</div>
          <div class="stat-label">Return on ad spend</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">493%</div>
          <div class="stat-label">Increase in qualified leads</div>
        </div>
      </div>
    </div>
  </section>

  <!-- WAITLIST -->
  <section class="waitlist-section" id="waitlist">
    <div class="container">
      <div class="waitlist-card fade-up">
        <span class="section-label">Limited Partnerships Available</span>
        <h2 class="section-title">Ready to Scale?</h2>
        <p class="section-subtitle">Join the waitlist. We'll reach out to see if we're the right fit to take your company to the next level.</p>

        <form id="waitlistForm" onsubmit="handleSubmit(event)">
          <div class="form-group form-row">
            <div>
              <label class="form-label" for="firstName">First Name</label>
              <input class="form-input" type="text" id="firstName" name="firstName" placeholder="John" required>
            </div>
            <div>
              <label class="form-label" for="lastName">Last Name</label>
              <input class="form-input" type="text" id="lastName" name="lastName" placeholder="Smith" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="email">Email Address</label>
            <input class="form-input" type="email" id="email" name="email" placeholder="john@yourcompany.com" required>
          </div>
          <div class="form-group">
            <label class="form-label" for="phone">Phone Number</label>
            <input class="form-input" type="tel" id="phone" name="phone" placeholder="(555) 000-0000">
          </div>
          <div class="form-group">
            <label class="form-label" for="company">Company Name</label>
            <input class="form-input" type="text" id="company" name="company" placeholder="Your Home Service Company" required>
          </div>
          <div class="form-group">
            <label class="form-label" for="revenue">Current Annual Revenue</label>
            <select class="form-input" id="revenue" name="revenue">
              <option value="" disabled selected>Select range</option>
              <option value="under-500k">Under $500K</option>
              <option value="500k-1m">$500K – $1M</option>
              <option value="1m-3m">$1M – $3M</option>
              <option value="3m-5m">$3M – $5M</option>
              <option value="5m-10m">$5M – $10M</option>
              <option value="10m-plus">$10M+</option>
            </select>
          </div>
          <button type="submit" class="btn-primary form-submit">
            Join the Waitlist
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>
          <p class="form-trust">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            No spam. No obligation. We'll only reach out if it's a fit.
          </p>
        </form>

        <!-- Success state -->
        <div id="formSuccess" style="display:none; text-align:center; padding: 40px 0;">
          <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin: 0 auto 20px;"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
          <h3 style="font-family: var(--font-heading); font-size: 24px; margin-bottom: 8px;">You're on the list.</h3>
          <p style="color: var(--text-light); font-size: 16px;">We'll be in touch soon if it's a fit. Keep building.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container">
      <img src="/images/logo-white.png" alt="Closer Launch" class="footer-logo">
      <p class="footer-text">&copy; 2026 Closer Launch. All rights reserved.</p>
      <div class="footer-links">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </footer>

  <script is:inline>
    // Header scroll effect
    const header = document.getElementById('header');
    window.addEventListener('scroll', () => {
      header.classList.toggle('scrolled', window.scrollY > 40);
    });

    // Fade-in on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

    // Form handling
    function handleSubmit(e) {
      e.preventDefault();
      // TODO: Connect to your form backend (Cloudflare Workers, Formspree, etc.)
      const form = document.getElementById('waitlistForm');
      const success = document.getElementById('formSuccess');
      form.style.display = 'none';
      success.style.display = 'block';
    }

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // Team modal data
    const teamData = {
      reese: {
        name: 'Reese',
        role: 'Partner',
        photo: '/images/reese.png',
        bio: 'Reese built and managed a sales division that closed $1.1M in three months, then scaled a regional operation to $2.5M annually. At Closer Launch, he brings that same execution to your business — optimizing every system from lead generation to customer experience so you scale faster and exit bigger.',
        socials: {
          linkedin: 'https://www.linkedin.com/in/reese-schmickrath-199a60333',
          twitter: null,
          instagram: 'https://www.instagram.com/reese_schmickrath/',
          email: 'reese@trycloserlaunch.com'
        }
      },
      ryan: {
        name: 'Ryan',
        role: 'Founder',
        photo: '/images/ryan.png',
        bio: 'Ryan scaled a SaaS startup to $500K ARR as VP of Sales, then bootstrapped a B2B agency to $30K/month solo before building Closer Launch. He doesn't sell retainers or promises — he creates partnerships. He teams up with ambitious home service owners and builds businesses engineered for large exits in 2–5 years. Your win is his win.',
        socials: {
          linkedin: 'https://www.linkedin.com/in/ryan-sanford-4a2287206/',
          twitter: null,
          instagram: 'https://www.instagram.com/ryanjakesanford/',
          email: 'ryan@trycloserlaunch.com'
        }
      },
      connor: {
        name: 'Connor',
        role: 'Partner',
        photo: '/images/connor.png',
        bio: 'Connor led marketing for a firm managing $115M+ in assets, attracting clients like Berkshire Hathaway and Amazon, and ran campaigns for Disney, Ford, and Honda. At Closer Launch, he brings that Fortune 500 playbook to home service companies — building the funnels, automation, and revenue systems that turn traffic into booked appointments at scale.',
        socials: {
          linkedin: 'https://www.linkedin.com/in/connor-erickson-6036751a6/',
          twitter: null,
          instagram: 'https://www.instagram.com/connorberickson/',
          email: 'connor@trycloserlaunch.com'
        }
      }
    };

    // Open team modal
    function openTeamModal(member) {
      const data = teamData[member];
      if (!data) return;

      document.getElementById('modalPhoto').src = data.photo;
      document.getElementById('modalPhoto').alt = data.name;
      document.getElementById('modalName').textContent = data.name;
      document.getElementById('modalRole').textContent = data.role;
      document.getElementById('modalBio').textContent = data.bio;

      // Build social icons
      const socialsContainer = document.getElementById('modalSocials');
      socialsContainer.innerHTML = '';

      // LinkedIn
      if (data.socials.linkedin) {
        socialsContainer.innerHTML += `
          <a href="${data.socials.linkedin}" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>`;
      }

      // Twitter (placeholder - disabled)
      socialsContainer.innerHTML += `
        <span class="social-icon social-icon-disabled" title="Coming soon" aria-label="Twitter (Coming soon)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </span>`;

      // Instagram
      if (data.socials.instagram) {
        socialsContainer.innerHTML += `
          <a href="${data.socials.instagram}" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>`;
      }

      // Email
      if (data.socials.email) {
        socialsContainer.innerHTML += `
          <a href="mailto:${data.socials.email}" class="social-icon" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>`;
      }

      document.getElementById('teamModal').classList.add('modal-active');
      document.body.style.overflow = 'hidden';
    }

    // Close team modal
    function closeTeamModal() {
      document.getElementById('teamModal').classList.remove('modal-active');
      document.body.style.overflow = '';
    }

    // Close modal on ESC key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeTeamModal();
    });
  </script>

</body>
</html>
